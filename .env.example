# Analytics IDs — OPTIONAL overrides.
#
# The production IDs are committed as defaults in src/lib/analytics-config.ts, so
# the site works without setting anything here. These vars only OVERRIDE those
# defaults per-deploy (e.g. a separate staging property). Set a var to an empty
# string to turn that provider off.
#
# Both are PUBLIC client-side identifiers (not secrets). Under the opt-out model
# they load by default unless the visitor opts out or sends GPC — and never on
# localhost or *.vercel.app.

# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity Project ID (the short id from the Clarity "Install manually" snippet)
NEXT_PUBLIC_CLARITY_ID=
